{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Den",
  "version": "0.2.1",
  "identifier": "com.jake.den",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Den",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "theme": "Dark",
        "backgroundColor": "#313338"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.livekit.cloud wss://*.livekit.cloud https://*.cloudflare.com https://*.r2.cloudflarestorage.com; img-src 'self' https://*.supabase.co https://*.r2.cloudflarestorage.com https://*.cloudflare.com data: blob:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4MjVFOTdFMUYyNzE5OUYKUldTZkdTY2ZmdWtsK0xLZ0UyRnZvcjdBUFFSNnM4bGY1cDdwd3lyNjZEZWZPZTVQRFdSK1dOREIK",
      "endpoints": [
        "https://github.com/Delimiters/den/releases/latest/download/latest.json"
      ]
    }
  }
}
